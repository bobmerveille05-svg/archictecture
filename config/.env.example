# Configuration示例 - 复制为 .env 并填入你的值

# API Keys (至少需要一个)
OPENAI_API_KEY=sk-...
# ANTHROPIC_KEY=sk-ant-...
# OPENROUTER_KEY=...

# 模型配置
MODEL_NAME=gpt-4o

# 数据库路径
DB_PATH=agent.db
MEMORY_DB_PATH=agent_memory.db

# Limites
MAX_ITERATIONS=20
TOOL_TIMEOUT=30
SANDBOX_DIR=/tmp/agent

# Chemins additionnels
TASKS_FILE=/tmp/agent/tasks.json
LOGS_DIR=logs

# 选项: Tracing (LangSmith)
# LANGSMITH_API_KEY=...
# LANGSMITH_PROJECT=agent

# Telegram Bot (Phase 3)
# TELEGRAM_BOT_TOKEN=...